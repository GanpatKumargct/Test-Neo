# Application
PROJECT_NAME="Bulk Selenium → NLP Test Case Converter"
API_V1_PREFIX=/api/v1

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=selenium_converter
POSTGRES_HOST=localhost
POSTGRES_PORT=55432

# Redis / Celery (use localhost when API/worker run on host, DB/Redis in Docker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security (change in production)
SECRET_KEY=change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# CORS (comma-separated origins; leave empty for dev localhost-only)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Observability (optional)
SENTRY_DSN=

